.DS_Store
~$*
.claude/
.gstack/

# Environment secrets — never commit real .env files. Templates (*.example) are allowed.
.env
.env.*
!.env.example
!.env.gcp.example
!*.env.example

# node
dev/dam/frontend/node_modules/
dev/*/node_modules/
node_modules/

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Terraform var files (user-specific; keep only *.example)
*.tfvars
!*.tfvars.example
