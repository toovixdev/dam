#!/usr/bin/env bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive

# ── MySQL 8 installed NATIVELY (no Docker) — like a real DB host ──
apt-get update -y
apt-get install -y mysql-server

sed -i 's/^bind-address.*/bind-address = 0.0.0.0/' /etc/mysql/mysql.conf.d/mysqld.cnf || true
systemctl enable mysql
systemctl restart mysql
for i in $(seq 1 30); do mysqladmin ping --silent 2>/dev/null && break; sleep 2; done

mysql <<'EOSQL'
ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '${root_password}';
CREATE DATABASE IF NOT EXISTS ${db_name};
CREATE USER IF NOT EXISTS 'app'@'%' IDENTIFIED BY '${root_password}';
GRANT ALL PRIVILEGES ON ${db_name}.* TO 'app'@'%';
CREATE USER IF NOT EXISTS 'dam_svc'@'%' IDENTIFIED BY '${root_password}';
GRANT SELECT, PROCESS ON *.* TO 'dam_svc'@'%';
FLUSH PRIVILEGES;
EOSQL

%{ if seed_b64 != "" ~}
echo '${seed_b64}' | base64 --decode > /tmp/seed.sql
mysql -uroot -p'${root_password}' < /tmp/seed.sql
%{ endif ~}

# ── Install Docker (so the TooVix DAM agent can run as a container; the static
#    binary works too) — installed on every DB host. ──
apt-get install -y ca-certificates curl gnupg
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg || true
chmod a+r /etc/apt/keyrings/docker.gpg
echo "deb [signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release; echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list
apt-get update -y && apt-get install -y docker-ce docker-ce-cli containerd.io || apt-get install -y docker.io
systemctl enable --now docker
