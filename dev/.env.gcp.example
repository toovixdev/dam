# ─────────────────────────────────────────────────────────────────────────────
# TooVix DAM — GCP test-env config template.
# On the VM:  cp .env.gcp.example .env  → fill in the SECRET placeholders below.
# The public URLs are already set for https://dam.suchirasoistories.in (behind Caddy).
# Do NOT commit the filled-in .env — it holds real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Client demo databases ──
CLIENT_PG_PASSWORD=CHANGE_ME
CLIENT_MYSQL_ROOT_PASSWORD=CHANGE_ME
CLIENT_MONGO_PASSWORD=CHANGE_ME

# ── DAM control plane ──
DAM_PG_PASSWORD=CHANGE_ME
DAM_CLICKHOUSE_PASSWORD=CHANGE_ME

# ── DAM API ──
DAM_API_PORT=3000
DAM_JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# ── Public URLs (served over HTTPS by Caddy on 443) ──
APP_BASE_URL=https://dam.suchirasoistories.in
API_PUBLIC_URL=https://dam.suchirasoistories.in
SIGNER_PUBLIC_URL=https://dam.suchirasoistories.in

# ── Azure AD SSO (OIDC) ── set redirect URI to the https callback below in the Entra app
AZURE_CLIENT_ID=CHANGE_ME
AZURE_TENANT_ID=CHANGE_ME
AZURE_CLIENT_SECRET=CHANGE_ME
AZURE_REDIRECT_URI=https://dam.suchirasoistories.in/auth/callback

# ── Okta SSO (OIDC) ── creds are configured PER TENANT in the Integrations GUI;
# only the redirect URI needs to match. Register it in the Okta app.
OKTA_REDIRECT_URI=https://dam.suchirasoistories.in/auth/okta/callback

# ── Google SSO (OIDC) ── creds are configured PER TENANT in the Integrations GUI;
# register this redirect URI in the Google Cloud OAuth client (HTTPS required).
GOOGLE_REDIRECT_URI=https://dam.suchirasoistories.in/auth/google/callback

# ── NATS ──
NATS_PORT=4222

# ── Billing (test): lower the current invoice for gateway test payments (unset = real bill) ──
BILLING_TEST_TOTAL_USD=5
