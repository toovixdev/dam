# ─── PHASE 1: build just the 3 databases (no DAM/agent needed) ───
region = "ap-south-1"   # Mumbai; use "us-east-1" etc. if you prefer

vm_databases = {
  "db-vm-a" = { vpc_cidr = "10.10.0.0/16", public_subnet = "10.10.0.0/24", private_subnet = "10.10.1.0/24", db_name = "orders" }
  "db-vm-b" = { vpc_cidr = "10.20.0.0/16", public_subnet = "10.20.0.0/24", private_subnet = "10.20.1.0/24", db_name = "customers" }
}

rds = {
  name             = "db-paas"
  engine_version   = "8.0"
  instance_class   = "db.t3.micro"
  db_name          = "billing"
  vpc_cidr         = "10.30.0.0/16"
  public_subnet    = "10.30.0.0/24"
  private_subnet_a = "10.30.1.0/24"
  private_subnet_b = "10.30.2.0/24"
}

deploy_agents = false
