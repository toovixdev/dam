#!/bin/bash
# Oracle Database 23ai Free on Docker + Unified Auditing, for the DAM Oracle collector.
#
# Image note: the official image (container-registry.oracle.com/database/free) requires
# accepting Oracle's licence before it can be pulled, which a headless boot can't do. The
# gvenzl community image is the same Oracle Free binaries repackaged and pulls anonymously,
# so it is the default here. Override var.oracle_vm.image to use the official one.
# NB: no `x` (command trace). The docker run and run_sql calls carry the SYS/app/dam-svc
# passwords on their command lines; tracing would write all three in cleartext to the log below
# (and to cloud-init-output.log). Progress is echoed explicitly instead.
set -euo pipefail
exec > >(tee /var/log/toovix-oracle-init.log) 2>&1

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y ca-certificates curl gnupg unzip

# ── Docker ──────────────────────────────────────────────────────────────────
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg
echo "deb [signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release; echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list
apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io || apt-get install -y docker.io
systemctl enable --now docker

# ── Oracle 23ai Free ────────────────────────────────────────────────────────
# Listens on 1521; the app schema lives in the pluggable DB (${pdb}), which is what
# clients and the DAM collector connect to as a service name.
docker rm -f oracle-free 2>/dev/null || true
docker run -d --name oracle-free --restart unless-stopped \
  -p 1521:1521 \
  -e ORACLE_PASSWORD='${sys_password}' \
  -e ORACLE_DATABASE='${pdb}' \
  -v oracle-data:/opt/oracle/oradata \
  '${image}'

# The first boot creates the database; that takes several minutes. Wait for the listener
# to actually answer rather than sleeping a fixed amount.
for i in $(seq 1 120); do
  if docker exec oracle-free bash -lc "echo 'SELECT 1 FROM dual;' | sqlplus -S -L sys/'${sys_password}'@localhost:1521/FREE as sysdba" 2>/dev/null | grep -q '1'; then
    echo "oracle: up after $i checks"
    break
  fi
  sleep 10
done

run_sql() {
  # $1 = connect string suffix (service), $2 = SQL
  docker exec -i oracle-free bash -lc "sqlplus -S -L sys/'${sys_password}'@localhost:1521/$1 as sysdba" <<SQL
WHENEVER SQLERROR EXIT SQL.SQLCODE
SET FEEDBACK ON
$2
EXIT
SQL
}

# ── App schema + seed (PII/PCI shaped, for classification) ──────────────────
run_sql '${pdb}' "
CREATE USER ${app_user} IDENTIFIED BY \"${app_password}\" QUOTA UNLIMITED ON USERS;
GRANT CREATE SESSION, CREATE TABLE, CREATE SEQUENCE TO ${app_user};

CREATE TABLE ${app_user}.CUSTOMERS (
  ID            NUMBER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  FULL_NAME     VARCHAR2(100),
  EMAIL         VARCHAR2(120),
  PHONE         VARCHAR2(20),
  AADHAAR       VARCHAR2(14),
  PAN_NUMBER    VARCHAR2(10),
  DATE_OF_BIRTH DATE
);

CREATE TABLE ${app_user}.PAYMENTS (
  ID          NUMBER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  CUSTOMER_ID NUMBER,
  CARD_NUMBER VARCHAR2(16),
  CVV         VARCHAR2(4),
  CARD_EXPIRY VARCHAR2(5),
  AMOUNT      NUMBER(12,2)
);

INSERT INTO ${app_user}.CUSTOMERS (FULL_NAME,EMAIL,PHONE,AADHAAR,PAN_NUMBER,DATE_OF_BIRTH)
  VALUES ('Asha Menon','asha.menon@example.com','9820011223','1234-5678-9012','ABCPM1234K',DATE '1988-04-12');
INSERT INTO ${app_user}.CUSTOMERS (FULL_NAME,EMAIL,PHONE,AADHAAR,PAN_NUMBER,DATE_OF_BIRTH)
  VALUES ('Rohan Iyer','rohan.iyer@example.com','9820044556','2345-6789-0123','BCDPI2345L',DATE '1991-09-30');
INSERT INTO ${app_user}.PAYMENTS (CUSTOMER_ID,CARD_NUMBER,CVV,CARD_EXPIRY,AMOUNT)
  VALUES (1,'4111111111111111','123','05/29',2450.00);
INSERT INTO ${app_user}.PAYMENTS (CUSTOMER_ID,CARD_NUMBER,CVV,CARD_EXPIRY,AMOUNT)
  VALUES (2,'5500005555555559','456','11/28',890.50);
COMMIT;
"

# ── Unified Auditing ────────────────────────────────────────────────────────
# 23ai runs pure unified auditing, so UNIFIED_AUDIT_TRAIL is populated without the
# relink/restart dance older releases needed. Auditing DML actions BY the app user avoids
# enumerating every object, and keeps Oracle's own background activity out of the trail —
# the same scoping problem solved with ON SCHEMA::dbo on SQL Server.
run_sql '${pdb}' "
CREATE AUDIT POLICY toovix_dml ACTIONS SELECT, INSERT, UPDATE, DELETE;
AUDIT POLICY toovix_dml BY ${app_user};
"

# ── The DAM collector's login ───────────────────────────────────────────────
# AUDIT_VIEWER grants SELECT on UNIFIED_AUDIT_TRAIL. SELECT_CATALOG_ROLE lets the
# classification scan read ALL_TAB_COLUMNS. Deliberately no data access beyond that.
run_sql '${pdb}' "
CREATE USER DAM_SVC IDENTIFIED BY \"${damsvc_password}\";
GRANT CREATE SESSION TO DAM_SVC;
GRANT AUDIT_VIEWER TO DAM_SVC;
GRANT SELECT_CATALOG_ROLE TO DAM_SVC;
"

# Record what the operator needs, without the passwords (those are in Secrets Manager).
cat > /etc/toovix-oracle.info <<INFO
service   = ${pdb}
port      = 1521
app_user  = ${app_user}
dam_user  = DAM_SVC
image     = ${image}
audit     = unified (policy toovix_dml, BY ${app_user})
INFO

echo "toovix: oracle init complete"
