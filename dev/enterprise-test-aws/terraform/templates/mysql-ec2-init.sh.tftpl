#!/usr/bin/env bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update -y
apt-get install -y mysql-server

sed -i 's/^bind-address.*/bind-address = 0.0.0.0/' /etc/mysql/mysql.conf.d/mysqld.cnf || true
systemctl enable mysql
systemctl restart mysql
for i in $(seq 1 30); do mysqladmin ping --silent 2>/dev/null && break; sleep 2; done

mysql <<'EOSQL'
ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '${root_password}';
CREATE DATABASE IF NOT EXISTS ${db_name};
CREATE USER IF NOT EXISTS 'app'@'%' IDENTIFIED BY '${root_password}';
GRANT ALL PRIVILEGES ON ${db_name}.* TO 'app'@'%';
CREATE USER IF NOT EXISTS 'dam_svc'@'%' IDENTIFIED BY '${root_password}';
GRANT SELECT, PROCESS ON *.* TO 'dam_svc'@'%';
FLUSH PRIVILEGES;
EOSQL

%{ if seed_b64 != "" ~}
echo '${seed_b64}' | base64 --decode > /tmp/seed.sql
mysql -uroot -p'${root_password}' < /tmp/seed.sql
%{ endif ~}
