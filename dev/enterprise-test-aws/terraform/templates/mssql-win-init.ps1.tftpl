<powershell>
# TooVix enterprise-test — SQL Server 2022 (Windows) first-boot config.
# Runs once at launch (as SYSTEM). Configures mixed-mode auth, sets the sa password,
# creates the seed DB + a least-privilege dam_svc login, loads seed data, installs Docker.
Start-Transcript -Path C:\toovix-init.log -Append
$ErrorActionPreference = 'Continue'

# ---------- 1. Wait for the preinstalled SQL Server to accept connections ----------
for ($i = 0; $i -lt 30; $i++) {
  sqlcmd -S localhost -E -b -Q "SELECT 1" 2>$null
  if ($LASTEXITCODE -eq 0) { break }
  Start-Sleep -Seconds 10
}

# ---------- 2. Enable mixed-mode (SQL + Windows) auth, restart the engine ----------
$reg = 'HKLM:\Software\Microsoft\Microsoft SQL Server\MSSQL16.MSSQLSERVER\MSSQLServer'
New-ItemProperty -Path $reg -Name 'LoginMode' -Value 2 -PropertyType DWORD -Force | Out-Null
Restart-Service -Name 'MSSQLSERVER' -Force
Start-Sleep -Seconds 25

$saPw = '${admin_password}'

# ---------- 3. sa password, seed DB, least-privilege DAM read-only login ----------
$setup = @"
ALTER LOGIN sa WITH PASSWORD = N'$saPw';
ALTER LOGIN sa ENABLE;
IF DB_ID('${db_name}') IS NULL CREATE DATABASE [${db_name}];
IF SUSER_ID('dam_svc') IS NULL CREATE LOGIN dam_svc WITH PASSWORD = N'$saPw', CHECK_POLICY = OFF;
GRANT VIEW SERVER STATE TO dam_svc;
"@
sqlcmd -S localhost -E -b -Q $setup

sqlcmd -S localhost -E -d ${db_name} -b -Q "IF DATABASE_PRINCIPAL_ID('dam_svc') IS NULL CREATE USER dam_svc FOR LOGIN dam_svc; ALTER ROLE db_datareader ADD MEMBER dam_svc;"

# ---------- 4. Seed data (T-SQL from seed/${db_name}.sql) ----------
%{ if seed_b64 != "" ~}
[System.IO.File]::WriteAllText('C:\seed.sql', [System.Text.Encoding]::UTF8.GetString([System.Convert]::FromBase64String('${seed_b64}')))
sqlcmd -S localhost -E -d ${db_name} -b -i C:\seed.sql
%{ endif ~}

# ---------- 5. Install Docker (Windows containers) ----------
# Same intent as the Linux DB hosts: let the TooVix DAM agent run as a container.
Install-WindowsFeature -Name Containers -ErrorAction SilentlyContinue
Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -ErrorAction SilentlyContinue
Install-Module -Name DockerMsftProvider -Repository PSGallery -Force -ErrorAction SilentlyContinue
Install-Package -Name docker -ProviderName DockerMsftProvider -Force -ErrorAction SilentlyContinue

Stop-Transcript
# Docker's containers feature + engine need a reboot to become active.
Restart-Computer -Force
</powershell>
