#!/usr/bin/env bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y mysql-client

%{ if seed_b64 != "" ~}
# ── Seed the Cloud SQL 'billing' database (retry until the private IP is reachable) ──
echo '${seed_b64}' | base64 --decode > /tmp/billing.sql
for i in $(seq 1 60); do
  if mysql -h '${cloudsql_host}' -u '${admin_user}' -p'${admin_password}' -e "SELECT 1" >/dev/null 2>&1; then
    mysql -h '${cloudsql_host}' -u '${admin_user}' -p'${admin_password}' < /tmp/billing.sql && break
  fi
  sleep 5
done
%{ endif ~}
