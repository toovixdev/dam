#!/usr/bin/env bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive

# ── MySQL 8 installed NATIVELY (no Docker) — like a real DB host ──
apt-get update -y
apt-get install -y mysql-server

# Listen on the private NIC (still firewalled to the subnet only).
sed -i 's/^bind-address.*/bind-address = 0.0.0.0/' /etc/mysql/mysql.conf.d/mysqld.cnf || true
systemctl enable mysql
systemctl restart mysql
for i in $(seq 1 30); do mysqladmin ping --silent 2>/dev/null && break; sleep 2; done

# Root password + the test database + an app user + a least-privilege service user.
mysql <<'EOSQL'
ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '${mysql_root_password}';
CREATE DATABASE IF NOT EXISTS ${db_name};
CREATE USER IF NOT EXISTS 'app'@'%' IDENTIFIED BY '${mysql_root_password}';
GRANT ALL PRIVILEGES ON ${db_name}.* TO 'app'@'%';
CREATE USER IF NOT EXISTS 'dam_svc'@'%' IDENTIFIED BY '${dam_svc_password}';
GRANT SELECT, PROCESS ON *.* TO 'dam_svc'@'%';
FLUSH PRIVILEGES;
EOSQL

%{ if seed_b64 != "" ~}
# ── Seed schema + data for this database ──
echo '${seed_b64}' | base64 --decode > /tmp/seed.sql
mysql -uroot -p'${mysql_root_password}' < /tmp/seed.sql
%{ endif ~}

%{ if deploy_agents ~}
# ── (Later) TooVix network agent — only rendered when deploy_agents = true ──
apt-get install -y ca-certificates curl gnupg
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg || true
echo "deb [signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release; echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list
apt-get update -y && apt-get install -y docker-ce docker-ce-cli containerd.io || apt-get install -y docker.io
systemctl enable --now docker
docker rm -f toovix-agent 2>/dev/null || true
docker run -d --name toovix-agent --restart unless-stopped \
  --network host --cap-add NET_RAW --cap-add NET_ADMIN \
  -e MODE=network -e DB_ENGINE=mysql -e TARGET_HOST=127.0.0.1 -e TARGET_PORT=3306 \
  -e TARGET_DB='${target_db}' -e CAPTURE_IFACE='${capture_iface}' \
  -e AGENT_ENROLL_TOKEN='${enroll_token}' -e CONTROL_PLANE='${control_plane_url}' \
  -e CLICKHOUSE_URL='${clickhouse_url}' -e CLICKHOUSE_USER='${clickhouse_user}' -e CLICKHOUSE_PASSWORD='${clickhouse_password}' \
  '${agent_image}'
%{ endif ~}
