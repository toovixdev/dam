# TooVix DAM — env template. Copy to dev/.env and fill in the CHANGE_ME values.
# dev/.env is gitignored; NEVER commit real secrets. (For GCP see .env.gcp.example.)

# ── Client demo databases ──
CLIENT_PG_PASSWORD=CHANGE_ME
CLIENT_MYSQL_ROOT_PASSWORD=CHANGE_ME
CLIENT_MONGO_PASSWORD=CHANGE_ME

# ── DAM control plane ──
DAM_PG_PASSWORD=CHANGE_ME
DAM_CLICKHOUSE_PASSWORD=CHANGE_ME

# ── DAM API ──
DAM_API_PORT=3000
DAM_JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# ── Public URLs (localhost for dev; the https domain on a server) ──
APP_BASE_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# ── Azure AD SSO (OIDC) — Azure Portal > App registrations ──
AZURE_CLIENT_ID=CHANGE_ME
AZURE_TENANT_ID=CHANGE_ME
AZURE_CLIENT_SECRET=CHANGE_ME
AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Okta & Google SSO (OIDC) — client creds are configured PER TENANT in the
# Integrations GUI (stored in the DB). Only the redirect URIs live here. ──
OKTA_REDIRECT_URI=http://localhost:5173/auth/okta/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ── NATS ──
NATS_PORT=4222

# ── Email (invitations & notifications) — provider-agnostic SMTP. Leave SMTP_HOST
# blank in dev: the API logs the invite link instead of sending real mail. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TooVix DAM <no-reply@toovix.security>

# ── Payment gateways (optional; preferred config is in-app at Settings → Payments).
# With NO Razorpay key set, Billing uses a public test-mode demo key (test cards only). ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_MODE=test
USD_TO_INR=83.5
