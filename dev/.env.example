# Client databases
CLIENT_PG_PASSWORD=client_secret_123
CLIENT_MYSQL_ROOT_PASSWORD=mysql_secret_123
CLIENT_MONGO_PASSWORD=mongo_secret_123

# DAM control plane
DAM_PG_PASSWORD=dam_control_secret
DAM_CLICKHOUSE_PASSWORD=dam_click_secret

# DAM API
DAM_API_PORT=3000
DAM_JWT_SECRET=dev-jwt-secret-change-in-prod

# Azure AD SSO (OIDC) — get these from Azure Portal > App registrations
AZURE_CLIENT_ID=your-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-value-here
AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# NATS
NATS_PORT=4222

# Email (user invitations & notifications) — provider-agnostic SMTP.
# Leave SMTP_HOST blank in dev: the API logs the invite link instead of sending real mail.
# For real delivery set these to your provider (Gmail, O365, Amazon SES-SMTP, Mailgun, Mailhog…).
APP_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TooVix DAM <no-reply@toovix.security>

# Payment gateways. Preferred: configure these in the app at Settings → Payments
# (stored in the DB, secrets server-side). These env vars are a fallback.
# With NO Razorpay key set, the Billing page opens Razorpay's real checkout UI with
# a public DEMO key (test cards only); add your own test key to actually take payments.
# Razorpay: Dashboard > Settings > API Keys (Test Mode) → rzp_test_… + secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_DEMO_KEY=rzp_test_1DP5mmOlF5G5ag   # override the built-in demo key if needed
# PayU: merchant Test key + salt (PayU's public test creds also work: gtKFFx / eCwWELxi).
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_MODE=test
# Invoices are USD; gateways charge INR at this rate. API_PUBLIC_URL must be reachable
# from the browser for PayU's redirect callback.
USD_TO_INR=83.5
API_PUBLIC_URL=http://localhost:3000
