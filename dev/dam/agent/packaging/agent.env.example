# TooVix DAM Agent configuration.
# Copy this per mode, e.g.  sudo cp agent.env.example /etc/toovix/agent-host.env
# then:  sudo systemctl enable --now dam-agent@host   (matches the MODE below).
#
# Get AGENT_ENROLL_TOKEN + CONTROL_PLANE from the DAM console → Deploy Monitoring.

# Capture mode: host (eBPF, below TLS) | network (passive, cleartext) | proxy (inline, can block)
# Must match the systemd instance name: agent-<mode>.env <-> dam-agent@<mode>.
MODE=host

# Database being monitored
DB_ENGINE=postgresql
TARGET_HOST=127.0.0.1
TARGET_PORT=5432

# Enrollment
AGENT_ENROLL_TOKEN=<enroll-token-from-Deploy-Monitoring>
CONTROL_PLANE=https://dam.example.com

# --- host (eBPF) mode ---
# Process name whose libssl to hook. Defaults from DB_ENGINE (postgres|mysqld). Override if needed:
#DB_PROC_COMM=postgres
# Tag a read 'large-result' when the total response exceeds this many bytes (default 1 MiB).
# Tune to your idea of a "large read"; 0 disables the tag.
#LARGE_RESULT_BYTES=1048576

# --- network mode ---
# Interface to sniff: any (all, incl. loopback) | <nic> (remote only) | lo (on-host only)
#CAPTURE_IFACE=any

# --- proxy mode (inline; clients connect THROUGH it, so it can block) ---
# LISTEN_PORT must be free — on the DB host itself it CANNOT equal the DB's own port.
#LISTEN_PORT=3307
#UPSTREAM=127.0.0.1:3306

# --- optional: schema classification (any mode) ---
#CLASSIFY=true
#DB_USER=dam_svc
#DB_PASSWORD=<db-reader-password>
#DB_NAME=<database-name>   # required for postgresql / mssql
